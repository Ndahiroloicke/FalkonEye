flowchart TB
    subgraph INPUT["1. Input"]
        CAM["USB Camera - live video frames"]
    end

    subgraph RECOGNIZE["2. Recognize"]
        DET["Face detection - find faces and landmarks"]
        ID["Face recognition - match to enrolled speaker"]
        LOCK["Speaker lock - follow one person only"]
        CAM --> DET
        DET --> ID
        ID --> LOCK
    end

    subgraph TRACK["3. Track"]
        STATE{"Is the locked speaker visible?"}
        CENTER["Centering - pan to keep face in middle of frame"]
        SEARCH["Search - sweep servo 0-180 until speaker is found"]
        LOCK --> STATE
        STATE -->|yes| CENTER
        STATE -->|no| SEARCH
    end

    subgraph COMMAND["4. Command"]
        ANGLE["Pan angle command - 0 to 180 degrees"]
        MQTT["MQTT broker - send angle and read status"]
        ESP["ESP8266 - move servo on D4"]
        CENTER --> ANGLE
        SEARCH --> ANGLE
        ANGLE --> MQTT
        MQTT --> ESP
        ESP -->|servo position| MQTT
        MQTT -->|feedback| CENTER
    end
